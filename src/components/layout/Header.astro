---
import { Icon } from "astro-icon/components";
---

<header class="w-full z-50 transition-all duration-700" id="header">
  <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#ff6b35] to-transparent opacity-0 transition-opacity duration-500" id="scroll-progress"></div>
  <div class="glass border-b border-white/5 w-full py-6" id="header-bg">
    <div class="container max-w-7xl mx-auto flex items-center justify-between h-20 px-4 md:px-6">
      <a href="/" class="flex items-center gap-4 group" aria-label="Inicio">
        <div class="relative">
          <img src="/images/sa_logo.png" alt="San Andreas RP" class="h-14 md:h-16 w-auto transition-transform duration-500 group-hover:scale-110" />
          <div class="absolute inset-0 blur-xl opacity-0 group-hover:opacity-50 transition-opacity duration-500" style="background: linear-gradient(135deg, #ff6b35, #ff1744);"></div>
        </div>
        <span class="hidden lg:block text-xl md:text-2xl font-bold text-white tracking-tight">San Andreas <span class="bg-gradient-to-r from-[#ff6b35] to-[#ff1744] bg-clip-text text-transparent">Roleplay</span></span>
      </a>

      <nav class="hidden md:flex items-center gap-10 md:gap-14" aria-label="Navegación">
        <a href="https://forum.sarp.es" target="_blank" class="relative py-2 text-gray-300 hover:text-[#ff6b35] font-semibold transition-colors text-sm md:text-base tracking-wide group">
          Foro
          <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#ff6b35] transition-all duration-500 group-hover:w-full"></span>
        </a>
        <a href="https://discord.gg/sa-rp" target="_blank" class="relative py-2 text-gray-300 hover:text-[#ff6b35] font-semibold transition-colors text-sm md:text-base tracking-wide group">
          <Icon class="w-5 h-5 inline-block mr-1.5 md:mr-2" name="mdi:discord" /> Discord
          <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#ff6b35] transition-all duration-500 group-hover:w-full"></span>
        </a>
        <a href="https://ucp.sarp.es" target="_blank" class="relative py-2 text-gray-300 hover:text-[#ff6b35] font-semibold transition-colors text-sm md:text-base tracking-wide group">
          Panel
          <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#ff6b35] transition-all duration-500 group-hover:w-full"></span>
        </a>
      </nav>

      <div class="flex items-center gap-4 md:gap-5">
        <a href="https://ucp.sarp.es/auth/signup" target="_blank" class="btn-primary text-sm py-3 px-6 md:px-8 relative overflow-hidden animate-breathe">
          <span class="relative z-10">Registrarse</span>
          <svg class="w-4 h-4 ml-1 md:ml-2 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
        </a>
        <button class="md:hidden text-white p-3 hover:text-[#ff6b35] transition-colors" onclick="document.getElementById('menu').classList.toggle('hidden')" aria-label="Menu">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
    <div id="menu" class="hidden md:hidden bg-[#0D0D0D]/98 backdrop-blur-xl border-t border-white/10 px-6 py-8 space-y-6">
      <a href="https://forum.sarp.es" target="_blank" class="flex items-center gap-3 text-gray-300 py-3 hover:text-[#ff6b35] text-lg font-medium transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 10H3V8h18v8zM6 15h2v-2H6v2zm4 0h2v-2h-2v2zm4 0h2v-2h-2v2z"/></svg>
        Foro
      </a>
      <a href="https://discord.gg/sa-rp" target="_blank" class="flex items-center gap-3 text-gray-300 py-3 hover:text-[#ff6b35] text-lg font-medium transition-colors">
        <Icon class="w-5 h-5" name="mdi:discord" />
        Discord
      </a>
      <a href="https://ucp.sarp.es" target="_blank" class="flex items-center gap-3 text-gray-300 py-3 hover:text-[#ff6b35] text-lg font-medium transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
        Panel
      </a>
      <a href="https://ucp.sarp.es/auth/signup" target="_blank" class="btn-primary w-full justify-center mt-4 py-4">
        Crear Cuenta
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</header>

<div class="fixed w-[300px] h-[300px] rounded-full bg-[#ff6b35]/15 blur-[150px] pointer-events-none z-40 transition-transform duration-1000 ease-out" id="ambient-glow"></div>

<div class="fixed bottom-10 right-10 z-50 hidden" id="back-to-top">
  <button onclick="window.scrollTo({top:0,behavior:'smooth'})" class="w-14 h-14 rounded-full bg-[#ff6b35] text-[#0a0a0a] flex items-center justify-center shadow-2xl hover:scale-110 transition-transform duration-300" style="box-shadow: 0 0 20px rgba(255,107,53,0.4), 0 0 40px rgba(255,107,53,0.2);">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
  </button>
</div>

<script>
  const header = document.getElementById('header');
  const headerBg = document.getElementById('header-bg');
  const scrollProgress = document.getElementById('scroll-progress');
  const backToTop = document.getElementById('back-to-top');
  const ambientGlow = document.getElementById('ambient-glow');
  
  document.addEventListener('mousemove', (e) => {
    if (ambientGlow) {
      ambientGlow.style.left = (e.clientX - 150) + 'px';
      ambientGlow.style.top = (e.clientY - 150) + 'px';
    }
  });
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = (currentScroll / docHeight) * 100;
    
    if (scrollProgress) {
      scrollProgress.style.width = progress + '%';
      scrollProgress.style.opacity = progress > 5 ? '1' : '0';
    }
    
    if (backToTop) {
      backToTop.classList.toggle('hidden', currentScroll < 500);
    }
    
    if (currentScroll > 50) {
      if (headerBg) {
        headerBg.style.background = 'rgba(10, 10, 10, 0.8)';
        headerBg.style.backdropFilter = 'blur(20px)';
      }
    } else {
      if (headerBg) {
        headerBg.style.background = 'transparent';
        headerBg.style.backdropFilter = 'none';
      }
    }
  }, { passive: true });
</script>