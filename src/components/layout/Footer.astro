<script>
  async function updateFooterStatus() {
    try {
      const res = await fetch('/api/playercount');
      const data = await res.json();
      const dot = document.getElementById('footerStatusDot');
      const ping = document.getElementById('footerStatusPing');
      const text = document.getElementById('footerStatusText');
      
      if (data && !data.error && data.online) {
        dot.className = 'w-2.5 h-2.5 rounded-full bg-green-500';
        ping.className = 'absolute inset-0 rounded-full bg-green-500 animate-ping opacity-75';
        text.textContent = 'Sistemas Web Operativos';
        text.className = 'text-[10px] text-gray-400 font-medium';
      } else {
        dot.className = 'w-2.5 h-2.5 rounded-full bg-red-500';
        ping.className = 'absolute inset-0 rounded-full bg-red-500';
        text.textContent = 'Servidor en mantenimiento';
        text.className = 'text-[10px] text-red-500 font-medium';
      }
    } catch (e) {
      const dot = document.getElementById('footerStatusDot');
      const text = document.getElementById('footerStatusText');
      dot.className = 'w-2.5 h-2.5 rounded-full bg-red-500';
      text.textContent = 'Error de conexión';
      text.className = 'text-[10px] text-red-500 font-medium';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateFooterStatus();
    setInterval(updateFooterStatus, 30000);
  });
</script>