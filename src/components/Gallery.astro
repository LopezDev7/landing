<section class="section relative w-full">
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden animate-gradient-shift"
    style="background: radial-gradient(ellipse at 30% 30%, rgba(255,107,53,0.06) 0%, transparent 60%), radial-gradient(ellipse at 70% 70%, rgba(255,23,68,0.06) 0%, transparent 60%); background-size: 200% 200%;"
  >
  </div>

  <div class="max-w-7xl mx-auto px-6 text-center relative w-full">
    <span class="badge mb-10 stagger-1">Galería</span>
    <h2 class="text-4xl md:text-6xl lg:text-7xl font-black mb-12 stagger-2">
      Paisajes de <span class="gradient-text">Los Santos</span>
    </h2>
    <p
      class="text-xl text-gray-400 mb-20 max-w-3xl mx-auto stagger-3 leading-relaxed"
    >
      Explora la belleza visual de nuestro mundo a través de capturas
      cinematográficas.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 stagger-4">
      <div
        class="md:col-span-8 relative rounded-3xl overflow-hidden group cursor-pointer"
      >
        <div class="aspect-[16/9] overflow-hidden">
          <img
            src="/images/features/casino.jpg"
            alt="Casino Los Santos"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"
        >
        </div>
        <div
          class="absolute bottom-8 left-8 right-8 text-left"
        >
          <p class="text-white font-bold text-2xl">Downtown Los Santos</p>
          <p class="text-gray-300 text-sm">El corazón de la ciudad</p>
        </div>
      </div>

      <div
        class="md:col-span-4 relative rounded-3xl overflow-hidden group cursor-pointer"
      >
        <div class="aspect-[3/4] overflow-hidden">
          <img
            src="/images/features/pershing.jpg"
            alt="Los Santos 2"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
            loading="lazy"
          />
        </div>
        <div
          class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"
        >
        </div>
        <div
          class="absolute bottom-6 left-6 right-6 text-left transform translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-700"
        >
          <p class="text-white font-bold text-xl">Plaza Pershing</p>
          <p class="text-gray-300 text-sm">Zona comercial</p>
        </div>
      </div>

      <div
        class="md:col-span-4 relative rounded-3xl overflow-hidden group cursor-pointer"
      >
        <div class="aspect-[3/4] overflow-hidden">
          <img
            src="/images/features/races.jpg"
            alt="Los Santos 3"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
            loading="lazy"
          />
        </div>
        <div
          class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"
        >
        </div>
        <div
          class="absolute bottom-6 left-6 right-6 text-left transform translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-700"
        >
          <p class="text-white font-bold text-xl">Circuito de Carreras</p>
          <p class="text-gray-300 text-sm">Velocidad extrema</p>
        </div>
      </div>

      <div
        class="md:col-span-8 relative rounded-3xl overflow-hidden group cursor-pointer"
      >
        <div class="aspect-[16/9] overflow-hidden">
          <img
            src="/images/features/truckers.jpg"
            alt="Los Santos 4"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
            loading="lazy"
          />
        </div>
        <div
          class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"
        >
        </div>
        <div
          class="absolute bottom-8 left-8 right-8 text-left transform translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-700"
        >
          <p class="text-white font-bold text-2xl">Ruta de Camiones</p>
          <p class="text-gray-300 text-sm">Logística realista</p>
        </div>
      </div>
    </div>
  </div>
</section>
