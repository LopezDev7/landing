---
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import "../styles/global.css";

const { title = "San Andreas Roleplay - El mejor servidor de Roleplay en español" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content="San Andreas Roleplay: La comunidad líder de roleplay basado en texto para GTA San Andreas. +8000 personajes registrados. ¡Únete ahora!" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="La comunidad líder de roleplay basado en texto para GTA San Andreas." />
    <meta property="og:image" content="https://sarp.es/images/logo.png" />
    <meta property="og:url" content="https://sarp.es" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="La comunidad líder de roleplay basado en texto para GTA San Andreas." />
    <meta name="twitter:image" content="https://sarp.es/images/logo.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen w-full flex flex-col bg-bg-dark">
    <div class="fixed inset-0 overflow-hidden pointer-events-none z-[-10]">
      <div class="absolute top-[5%] left-[5%] w-[600px] h-[600px] rounded-full bg-orange-600/10 blur-[150px]"></div>
      <div class="absolute top-[40%] left-[50%] transform -translate-x-1/2 w-[500px] h-[500px] rounded-full bg-orange-600/20 blur-[150px]"></div>
      <div class="absolute bottom-[5%] right-[5%] w-[550px] h-[550px] rounded-full bg-red-600/10 blur-[150px]"></div>
    </div>

    <Header />
    <main class="flex-1 flex flex-col items-center w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>